# Production environment — copy to .env.production and fill in values
# Used by: pnpm db:migrate:prod  and  pnpm seed:prod

# Supabase cloud — Settings > Database > Connection string (Session mode, port 5432)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Supabase cloud — Settings > API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
