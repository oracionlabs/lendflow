{
  "name": "lendflow",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n client,server -c cyan,green \"pnpm --filter client dev\" \"pnpm --filter server dev\"",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "supabase:start": "npx supabase start --workdir supabase",
    "supabase:stop": "npx supabase stop --workdir supabase",
    "db:migrate": "pnpm --filter server db:migrate",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
